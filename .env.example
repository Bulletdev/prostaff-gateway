PORT=4444

# JWT secret for service-to-service authentication.
# MUST be different from the prostaff-api user JWT secret.
# Tokens issued to this gateway must include aud: "prostaff-riot-gateway".
# Generate with: openssl rand -hex 32
INTERNAL_JWT_SECRET=change-me-generate-a-dedicated-gateway-secret

RIOT_API_KEY=RGAPI-your-key-here
RIOT_API_TIMEOUT=5s

RIOT_RATE_LIMIT_PER_SECOND=20
RIOT_RATE_LIMIT_BURST=20
RIOT_RATE_LIMIT_PER_2MIN=100

REDIS_URL=redis://redis:6379/1
CACHE_ENABLED=true
CACHE_L1_MAX_SIZE=10000

CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT=60
CIRCUIT_BREAKER_COOLDOWN=30

LOG_LEVEL=info
